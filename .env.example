# Azure DevOps Personal Access Token (needs Wiki > Read permission)
# Generate at: https://dev.azure.com/{your-org}/_usersSettings/tokens
AZURE_DEVOPS_PAT=your-pat-here

# Azure DevOps wiki details
DEVOPS_ORG=your-org
DEVOPS_PROJECT=your-project
DEVOPS_WIKI=your-project.wiki

# Azure Blob Storage
# Find at: Azure Portal > Storage Account > Access Keys
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=your-container-name

# Azure OpenAI (for embeddings + chat)
# Find at: Azure Portal > OpenAI resource > Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o

# Azure AI Search
# Find at: Azure Portal > Search resource > Keys
AZURE_SEARCH_ENDPOINT=https://your-resource.search.windows.net
AZURE_SEARCH_API_KEY=your-key-here
AZURE_SEARCH_INDEX_NAME=wiki-index
